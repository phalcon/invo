# Docker / project
PROJECT_PREFIX=invo
PHP_VERSION=8.2
PHALCON_VARIANT=v5

# Port the application listens on (host and container). Change to use a different port.
APP_PORT=8080

UID=1000
GID=1000

# Application
VIEWS_DIR=themes/invo/
BASE_URI=/
APP_URL=http://127.0.0.1:8080

# Database (internal compose network only; NOT published to the host)
DB_ADAPTER=Mysql
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_NAME=invo
DB_CHARSET=utf8
